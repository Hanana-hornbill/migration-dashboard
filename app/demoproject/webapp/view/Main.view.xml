<mvc:View
    controllerName="demoproject.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt">

<tnt:ToolPage>

    <tnt:sideContent>

        <tnt:SideNavigation>

            <tnt:NavigationList>

                <tnt:NavigationListItem
                    text="Assessment Agent"
                    key="assessment"
                    select="onAssessmentPress"/>

                <tnt:NavigationListItem
                    text="Pre-Migration Agent"/>

                <tnt:NavigationListItem
                    text="Migration Agent"/>

                <tnt:NavigationListItem
                    text="Migration Validation Agent"/>

            </tnt:NavigationList>

        </tnt:SideNavigation>

    </tnt:sideContent>

    <tnt:mainContents>

        <App id="mainApp"/>

    </tnt:mainContents>

</tnt:ToolPage>

</mvc:View>