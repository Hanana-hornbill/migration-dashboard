<mvc:View
    controllerName="migrationdashboard.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt">



    <tnt:ToolPage>

        <!-- ================================================= -->
        <!-- HEADER -->
        <!-- ================================================= -->

        <tnt:header>

            <tnt:ToolHeader>

                <Button
                    icon="sap-icon://menu2"
                    type="Transparent" />

                <Image
                    src="https://www.sap.com/dam/application/shared/logos/sap-logo-svg.svg"
                    height="2rem"
                    class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />

                <Title
                    text="HANA Cloud Migration Assistant"
                    level="H3" />

                <ToolbarSpacer />

                <SearchField
                    width="25rem"
                    placeholder="Search..." />

                <ToolbarSpacer />

                <Button
                    icon="sap-icon://world"
                    type="Transparent" />

                <Button
                    icon="sap-icon://bell"
                    type="Transparent" />

                <Button
                    icon="sap-icon://history"
                    type="Transparent" />

                <Avatar
                    initials="AN"
                    class="sapUiTinyMarginBegin" />

            </tnt:ToolHeader>

        </tnt:header>

        <!-- ================================================= -->
        <!-- SIDEBAR -->
        <!-- ================================================= -->

        <tnt:sideContent>

            <tnt:SideNavigation>

                <tnt:NavigationList>

                    <tnt:NavigationListItem
                        text="Assessment Agent"
                        select="onAssessmentPress" />

                    <tnt:NavigationListItem
                        text="Pre-Migration Agent"
                        select="onPreMigrationPress" />

                    <tnt:NavigationListItem
                        text="Migration Agent"
                        select="onMigrationPress" />

                    <tnt:NavigationListItem
                        text="Migration Validation Agent"
                        select="onValidationPress" />

                </tnt:NavigationList>

            </tnt:SideNavigation>

        </tnt:sideContent>

        <!-- ================================================= -->
        <!-- MAIN CONTENT -->
        <!-- ================================================= -->

        <tnt:mainContents>

            <App id="mainApp">

                <!-- ========================================= -->
                <!-- HOME PAGE -->
                <!-- ========================================= -->

                <Page
                    id="homePage"
                    title="Dashboard">

                    <content>

                        <VBox class="sapUiMediumMargin">

                            <Title
                                text="Welcome"
                                level="H2" />

                            <Text
                                text="Manage and assess SAP HANA databases dynamically." />

                            <Button
                                text="Connect Database"
                                icon="sap-icon://database"
                                press="onOpenConnectPage"
                                class="sapUiSmallMarginTop" />

                            <!-- ================================= -->
                            <!-- SAVED CONNECTIONS -->
                            <!-- ================================= -->

                            <Title
                                text="Saved Connections"
                                level="H3"
                                class="sapUiMediumMarginTop" />

                            <Table
                                items="{connections>/}">

                                <columns>

                                    <Column>
                                        <Text text="Instance" />
                                    </Column>

                                    <Column>
                                        <Text text="Host" />
                                    </Column>

                                    <Column>
                                        <Text text="Status" />
                                    </Column>

                                </columns>

                                <items>

                                    <ColumnListItem
                                        type="Active"
                                        press="onConnectionSelect">

                                        <cells>

                                            <Text
                                                text="{connections>INSTANCE_NAME}" />

                                            <Text
                                                text="{connections>HOSTNAME}" />

                                            <Text
                                                text="{connections>STATUS}" />

                                        </cells>

                                    </ColumnListItem>

                                </items>

                            </Table>

                        </VBox>

                    </content>

                </Page>

                <!-- ========================================= -->
                <!-- CONNECT DATABASE PAGE -->
                <!-- ========================================= -->

                <Page
                    id="connectPage"
                    title="Connect Database"
                    showNavButton="true"
                    navButtonPress="onNavBack">

                    <content>

                        <VBox class="sapUiMediumMargin">

                            <Label text="Host" />

                            <Input
                                id="hostInput"
                                placeholder="Enter Host" />

                            <Label text="Port" />

                            <Input
                                id="portInput"
                                placeholder="Port Number" />

                            <Label text="Username" />

                            <Input
                                id="userInput"
                                placeholder="Username" />

                            <Label text="Password" />

                            <Input
                                id="passwordInput"
                                type="Password"
                                placeholder="Enter Password" />

                            <Button
                                text="Connect"
                                type="Emphasized"
                                press="onConnect"
                                class="sapUiSmallMarginTop" />

                        </VBox>

                    </content>

                </Page>

                <!-- ========================================= -->
                <!-- ASSESSMENT RESULTS PAGE -->
                <!-- ========================================= -->

                <Page
                    id="assessmentPage"
                    title="Assessment Results"
                    showNavButton="true"
                    navButtonPress="onNavBack">

                    <content>

                        <VBox class="sapUiMediumMargin">

                            <Title
                                text="Database Assessment Overview"
                                level="H2"
                                class="sapUiSmallMarginBottom" />

                            <HBox
                                wrap="Wrap"
                                justifyContent="Start">

                                <!-- USERS TILE -->

                                <GenericTile
                                    class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                    header="Users">

                                    <TileContent>

                                        <NumericContent
                                            value="{metrics>/users}" />

                                    </TileContent>

                                </GenericTile>

                                <!-- TABLES TILE -->

                                <GenericTile
                                    class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                    header="Tables">

                                    <TileContent>

                                        <NumericContent
                                            value="{metrics>/tables}" />

                                    </TileContent>

                                </GenericTile>

                                <!-- SCHEMAS TILE -->

                                <GenericTile
                                    class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                    header="Schemas">

                                    <TileContent>

                                        <NumericContent
                                            value="{metrics>/schemas}" />

                                    </TileContent>

                                </GenericTile>

                                <!-- MEMORY USED TILE -->

                                <GenericTile
                                    header="Memory Used">

                                    <TileContent>

                                        <NumericContent
                                            value="{metrics>/memoryUsed}" />

                                    </TileContent>

                                </GenericTile>

                            </HBox>

                            <HBox class="sapUiSmallMarginTop" wrap="Wrap" justifyContent="SpaceBetween">
                                <VBox>
                                    <Button
                                        text="View SQL Analysis"
                                        press="onViewSqlAnalysis" />
                                    <Button
                                        text="View Memory Configuration"
                                        press="onViewMemoryConfig" />
                                    <Button
                                        text="View Scale-Out Configuration"
                                        press="onViewScaleOutConfig" />
                                </VBox>

                                <VBox>
                                    <Button
                                        text="Run History"
                                        icon="sap-icon://history"
                                        type="Emphasized"
                                        press="onViewRunHistory" />
                                </VBox>
                            </HBox>

                        </VBox>

                    </content>

                    

                </Page>
                <!--sql analysis preview-->
                <Page
                    id="sqlAnalysisPage"
                    title="SQL Memory Analysis"
                    showNavButton="true"
                    navButtonPress="onNavBack">

                    <content>

                        <Table
                            items="{sqlAnalysis>/}">

                            <columns>

                                <Column>
                                    <Text text="Avg Memory GB" />
                                </Column>

                                <Column>
                                    <Text text="Peak Memory GB" />
                                </Column>

                                <Column>
                                    <Text text="Execution Count" />
                                </Column>

                                <Column>
                                    <Text text="Avg Exec MS" />
                                </Column>

                                <Column>
                                    <Text text="SQL Preview" />
                                </Column>

                            </columns>

                            <items>

                                <ColumnListItem>

                                    <cells>

                                        <Text text="{sqlAnalysis>AVG_MEMORY_GB}" />

                                        <Text text="{sqlAnalysis>PEAK_MEMORY_GB}" />

                                        <Text text="{sqlAnalysis>EXECUTION_COUNT}" />

                                        <Text text="{sqlAnalysis>AVG_EXEC_MS}" />

                                        <Text text="{sqlAnalysis>SQL_PREVIEW}" />

                                    </cells>

                                </ColumnListItem>

                            </items>

                        </Table>

                    </content>

                </Page>
                <Page
                    id="memoryConfigPage"
                    title="Memory Configuration Analysis"
                    showNavButton="true"
                    navButtonPress="onNavBack">

                    <content>

                        <Table
                            items="{memoryConfig>/}">

                            <columns>

                                <Column>
                                    <Text text="File" />
                                </Column>

                                <Column>
                                    <Text text="Section" />
                                </Column>

                                <Column>
                                    <Text text="Key" />
                                </Column>

                                <Column>
                                    <Text text="Value" />
                                </Column>

                                <Column>
                                    <Text text="Layer" />
                                </Column>

                            </columns>

                            <items>

                                <ColumnListItem>

                                    <cells>

                                        <Text text="{memoryConfig>FILE_NAME}" />

                                        <Text text="{memoryConfig>SECTION_NAME}" />

                                        <Text text="{memoryConfig>CONFIG_KEY}" />

                                        <Text text="{memoryConfig>CONFIG_VALUE}" />

                                        <Text text="{memoryConfig>LAYER_NAME}" />

                                    </cells>

                                </ColumnListItem>

                            </items>

                        </Table>

                    </content>

                </Page>
                <Page
                        id="scaleOutConfigPage"
                        title="Scale-Out Configuration"
                        showNavButton="true"
                        navButtonPress="onNavBack">

                        <content>

                            <Table
                                items="{scaleOutConfig>/}">

                                <columns>

                                    <Column>
                                        <Text text="File" />
                                    </Column>

                                    <Column>
                                        <Text text="Section" />
                                    </Column>

                                    <Column>
                                        <Text text="Key" />
                                    </Column>

                                    <Column>
                                        <Text text="Value" />
                                    </Column>

                                    <Column>
                                        <Text text="Layer" />
                                    </Column>

                                </columns>

                                <items>

                                    <ColumnListItem>

                                        <cells>

                                            <Text text="{scaleOutConfig>FILE_NAME}" />

                                            <Text text="{scaleOutConfig>SECTION_NAME}" />

                                            <Text text="{scaleOutConfig>CONFIG_KEY}" />

                                            <Text text="{scaleOutConfig>CONFIG_VALUE}" />

                                            <Text text="{scaleOutConfig>LAYER_NAME}" />

                                        </cells>

                                    </ColumnListItem>

                                </items>

                            </Table>

                        </content>

                </Page>
                <!-- ========================================= -->
                <!-- PRE-MIGRATION PAGE -->
                <!-- ========================================= -->

                <Page
                    id="preMigrationPage"
                    title="Pre-Migration">

                    <content>

                        <VBox class="sapUiMediumMargin">

                            <Title
                                text="Pre-Migration Module" />

                            <Text text="" />

                        </VBox>

                    </content>

                </Page>

                <!-- ========================================= -->
                <!-- MIGRATION PAGE -->
                <!-- ========================================= -->

                <Page
                    id="migrationPage"
                    title="Migration">

                    <content>

                        <VBox class="sapUiMediumMargin">

                            <Title
                                text="Migration Module" />

                            <Text text="" />

                        </VBox>

                    </content>

                </Page>

                <!-- ========================================= -->
                <!-- VALIDATION PAGE -->
                <!-- ========================================= -->

                <Page
                    id="validationPage"
                    title="Validation">

                    <content>

                        <VBox class="sapUiMediumMargin">

                            <Title
                                text="Validation Module" />

                            <Text text="" />

                        </VBox>

                    </content>

                </Page>

                <!-- ========================================= -->
                <!-- RUN HISTORY PAGE (SEPARATE XML) -->
                <!-- ========================================= -->

                <mvc:XMLView
                    viewName="migrationdashboard.view.runHistory"
                    id="runHistoryXml" />

                <mvc:XMLView
                    viewName="migrationdashboard.view.runHistoryDetail"
                    id="runHistoryDetailXml" />

            </App>

        </tnt:mainContents>

    </tnt:ToolPage>

</mvc:View>