<mvc:View
    controllerName="migrationdashboard.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt">

    <tnt:ToolPage>

        <!-- Header -->
        <tnt:header>

    <tnt:ToolHeader>
                                              
        <Button
            icon="sap-icon://menu2"
            type="Transparent"/>

        <Image
            src="https://www.sap.com/dam/application/shared/logos/sap-logo-svg.svg"
            height="2rem"
            class="sapUiTinyMarginBegin sapUiTinyMarginEnd"/>

        <Title
            text="HANA Cloud Migration Assistant"
            level="H3"/>

        <ToolbarSpacer/>

        <SearchField
            width="25rem"
            placeholder='Search...'/>

        <ToolbarSpacer/>

        <Button
            icon="sap-icon://world"
            type="Transparent"/>

        <Button
            icon="sap-icon://bell"
            type="Transparent"/>

        <Button
            icon="sap-icon://history"
            type="Transparent"/>

        <Avatar
            initials="AN"
            class="sapUiTinyMarginBegin"/>

    </tnt:ToolHeader>

</tnt:header>

        <!-- Sidebar -->
        <tnt:sideContent>

            <tnt:SideNavigation>

                <tnt:NavigationList>

                    <tnt:NavigationListItem
                        text="Assessment Agent"
                        select="onAssessmentPress"/>

                    <tnt:NavigationListItem
                        text="Pre-Migration Agent"
                        select="onPreMigrationPress"/>

                    <tnt:NavigationListItem
                        text="Migration Agent"
                        select="onMigrationPress"/>

                    <tnt:NavigationListItem
                        text="Migration Validation Agent"
                        select="onValidationPress"/>

                </tnt:NavigationList>

            </tnt:SideNavigation>

        </tnt:sideContent>

        <!-- Main Content -->
        <tnt:mainContents>

            <App id="mainApp">

    <!-- ===================================== -->
    <!-- HOME PAGE -->
    <!-- ===================================== -->

    <Page
        id="homePage"
        title="Dashboard">

        <content>

            <VBox class="sapUiMediumMargin">

                <Title
                    text="Welcome"
                    level="H2" />

                <Text
                    text="Manage and assess SAP HANA databases dynamically." />

                <Button
                    text="Connect Database"
                    icon="sap-icon://database"
                    press="onOpenConnectPage"
                    class="sapUiSmallMarginTop" />

                
                    

            
            <Title
                text=" Saved Connections"
                level="H3"
                class="sapUiMediumMarginTop" />
            <Table
                items="{connections>/}">

                <columns>

                    <Column>
                        <Text text="Instance" />
                    </Column>

                    <Column>
                        <Text text="Host" />
                    </Column>

                    <Column>
                        <Text text="Status" />
                    </Column>

                </columns>

                <items>

                    <ColumnListItem
                        type="Active"
                        press="onConnectionSelect">

                        <cells>

                            <Text
                                text="{connections>INSTANCE_NAME}" />

                            <Text
                                text="{connections>HOSTNAME}" />

                            <Text
                                text="{connections>STATUS}" />

                        </cells>

                    </ColumnListItem>

                </items>

            </Table>

        </VBox>
        </content>


    </Page>

    <!-- ===================================== -->
    <!-- CONNECT DATABASE PAGE -->
    <!-- ===================================== -->

    <Page
        id="connectPage"
        title="Connect Database"
        showNavButton="true"
        navButtonPress="onNavBack">

        <content>

            <VBox class="sapUiMediumMargin">

                <Label text="Host" />

                <Input
                    id="hostInput"
                    placeholder="Enter Host" />

                <Label text="Port" />

                <Input
                    id="portInput"
                    placeholder="Port number" />

                <Label text="Username" />

                <Input
                    id="userInput"
                    placeholder="Username" />

                <Label text="Password" />

                <Input
                    id="passwordInput"
                    type="Password"
                    placeholder="Enter Password" />

                <Button
                    text="Connect"
                    type="Emphasized"
                    press="onConnect"
                    class="sapUiSmallMarginTop" />

            </VBox>

        </content>

    </Page>

    <!-- ===================================== -->
    <!-- ASSESSMENT RESULTS PAGE -->
    <!-- ===================================== -->

    <Page
        id="assessmentPage"
        title="Assessment Results"
        showNavButton="true"
        navButtonPress="onNavBack">

        <content>

            <HBox
                wrap="Wrap"
                class="sapUiMediumMargin">

                <GenericTile
                    header="Users">

                    <TileContent>

                        <NumericContent
                            value="{metrics>/users}" />

                    </TileContent>

                </GenericTile>

                <GenericTile
                    header="Tables">

                    <TileContent>

                        <NumericContent
                            value="{metrics>/tables}" />

                    </TileContent>

                </GenericTile>

                <GenericTile
                    header="Schemas">

                    <TileContent>

                        <NumericContent
                            value="{metrics>/schemas}" />

                    </TileContent>

                </GenericTile>

            </HBox>

        </content>

    </Page>

    <!-- ===================================== -->
    <!-- SAVED CONNECTIONS PAGE -->
    <!-- ===================================== -->
<!--
    <Page
        id="savedConnectionsPage"
        title="Saved Connections"
        showNavButton="true"
        navButtonPress="onNavBack">

        <content>

            
        </content>

    </Page>
-->
    <!-- ===================================== -->
    <!-- PRE-MIGRATION PAGE -->
    <!-- ===================================== -->

    <Page
        id="preMigrationPage"
        title="Pre-Migration">

        <content>

            <VBox class="sapUiMediumMargin">

                <Title
                    text="Pre-Migration Module" />

                <Text
                    text=" " />

            </VBox>

        </content>

    </Page>

<!--migration page-->
    <Page
        id="migrationPage"
        title="Migration">

        <content>

            <VBox class="sapUiMediumMargin">

                <Title
                    text="Migration Module" />

                <Text
                    text=" " />

            </VBox>

        </content>

    </Page>
    <!-- ===================================== -->
    <!-- VALIDATION PAGE -->
    <!-- ===================================== -->

    <Page
        id="validationPage"
        title="Validation">

        <content>

            <VBox class="sapUiMediumMargin">

                <Title
                    text="Validation Module" />

                <Text
                    text=" " />

            </VBox>

        </content>

    </Page>

</App>

        </tnt:mainContents>

    </tnt:ToolPage>

</mvc:View>
